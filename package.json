  "bugs": {
    "url": "https://github.com/T3pp31/Shogi/issues"
  },
  "homepage": "https://github.com/T3pp31/Shogi#readme",
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "jest": "^30.3.0"
  }
}
